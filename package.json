{
  "scripts": {
    "build": "zile",
    "changeset:publish": "zile publish:prepare && changeset publish && zile publish:post",
    "changeset:version": "changeset version",
    "check": "biome check --fix --unsafe",
    "check:types": "tsc -b && pnpm -r check:types",
    "clac": "node --import tsx src/bin.ts",
    "dev": "zile dev",
    "test": "vitest"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@changesets/cli": "latest",
    "@types/node": "latest",
    "tsx": "^4.21.0",
    "typescript": "latest",
    "vitest": "latest",
    "zile": "latest"
  },
  "packageManager": "pnpm@10.30.2",
  "[!start-pkg]": "",
  "name": "clac",
  "type": "module",
  "version": "0.0.0",
  "main": "./dist/index.js",
  "license": "MIT",
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@toon-format/toon": "^2.1.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "sideEffects": false,
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "src": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./Register": {
      "types": "./dist/Register.d.ts",
      "src": "./src/Register.ts",
      "default": "./dist/Register.js"
    }
  }
}
